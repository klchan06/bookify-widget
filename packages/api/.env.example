# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bookify?schema=public"

# JWT
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:3000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Resend (Email) - Free tier: 100 emails/day
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Bookify <noreply@bookify.nl>"

# Google Calendar OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/api/calendar/google/callback"
