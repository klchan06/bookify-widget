# Database
DATABASE_URL="postgresql://bookify:bookify@localhost:5432/bookify?schema=public"

# JWT
JWT_SECRET="change-me-to-a-random-secret"
JWT_EXPIRES_IN="7d"

# Email (Resend - free tier: 100 emails/day)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="noreply@bookify.nl"

# Google Calendar
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/api/calendar/google/callback"

# App
API_URL="http://localhost:3001"
WIDGET_URL="http://localhost:3002"
DASHBOARD_URL="http://localhost:3003"
NODE_ENV="development"
PORT=3001
